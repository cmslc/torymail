DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=torymail

# Mail server settings
MAIL_STORAGE_PATH=/var/mail/vhosts
MAIL_SERVER_HOSTNAME=mail.yourdomain.com

# IMAP/SMTP ports
IMAP_PORT=993
SMTP_PORT=587

# Encryption key for stored passwords
ENCRYPTION_KEY=change-this-to-random-string

# App URL
APP_URL=https://yourdomain.com
